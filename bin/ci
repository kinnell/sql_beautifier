#!/bin/bash
set -euo pipefail

################################################################################
## Constants
################################################################################

readonly RESET='\033[0m'
readonly BOLD='\033[1;33m'
readonly TITLE='\033[35m'
readonly DIM='\033[2m'
readonly GREEN='\033[32m'
readonly RED='\033[31m'

readonly SUCCESS_INDICATOR="${GREEN}✓${RESET}"
readonly FAILURE_INDICATOR="${RED}✗${RESET}"
readonly WHITE='\033[1;37m'

QUIET="false"
RESULTS=()

if [[ "${1:-}" == "--quiet" ]]; then
  QUIET="true"
fi

################################################################################
## Display Helpers
################################################################################

function print_error()   { echo -e "${RED}✗ ERROR:${RESET} ${1}${2:+ ${DIM}(${2})${RESET}}"; }
function print_success() { echo -e "${GREEN}✓ SUCCESS:${RESET} ${1}${2:+ ${DIM}(${2})${RESET}}"; }

function print_heading() {
  local text="$1"
  local subtitle="${2:-}"

  echo ""
  echo -e "${TITLE}${text}${RESET}"
  [[ -n "$subtitle" ]] && echo -e "${DIM}${subtitle}${RESET}"
  echo ""
}

function print_banner() {
  local text="$1"
  local subtitle="${2:-}"

  echo -e "${BOLD}${text}${RESET}"
  [[ -n "$subtitle" ]] && echo -e "${DIM}${subtitle}${RESET}"
}

function print_result() {
  local title="$1"
  local duration="$2"
  local passed="$3"

  if [[ "$passed" == "true" ]]; then
    print_success "${title} passed" "${duration}"
  else
    print_error "${title} failed" "${duration}"
  fi
}

function print_quiet_result() {
  local title="$1"
  local duration="$2"
  local passed="$3"

  if [[ "$passed" == "true" ]]; then
    print_success "${title} passed" "${duration}"
  else
    print_error "${title} failed" "${duration}"
  fi
}

################################################################################
## Runner
################################################################################

function run_step() {
  local title="$1"
  shift
  local command="$*"

  local passed output
  local SECONDS=0

  if [[ "$QUIET" == "true" ]]; then
    if output=$(eval "$command" 2>&1); then
      passed="true"
    else
      passed="false"
    fi

    print_quiet_result "$title" "${SECONDS}s" "$passed"

    if [[ "$passed" == "false" ]]; then
      echo "$output"
    fi
  else
    print_heading "$title" "$command"

    if eval "$command"; then
      passed="true"
    else
      passed="false"
    fi

    print_result "$title" "${SECONDS}s" "$passed"
  fi

  RESULTS+=("$passed")
}

function all_passed() {
  for result in "${RESULTS[@]}"; do
    if [[ "$result" != "true" ]]; then
      return 1
    fi
  done
  return 0
}

################################################################################
## Main
################################################################################

if [[ "$QUIET" == "false" ]]; then
  print_banner "Continuous Integration" "Running tests and style checks"
fi

SECONDS=0

run_step "RSpec test suite" "bundle exec rspec"
run_step "RuboCop style checks" "bundle exec rubocop"

if [[ "$QUIET" == "true" ]]; then
  if ! all_passed; then
    exit 1
  fi
else
  if all_passed; then
    print_result "Continuous Integration" "${SECONDS}s" "true"
  else
    print_result "Continuous Integration" "${SECONDS}s" "false"
    exit 1
  fi
fi
